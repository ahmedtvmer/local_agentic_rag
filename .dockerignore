# Environment & Secrets
# ==============================================================================
.env
.env.*
!.env.example

# ==============================================================================
# IDE & Editor Config
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ==============================================================================
# Docker (don't send Docker config into the image)
# ==============================================================================
DockerFile
Dockerfile
docker-compose.yaml
docker-compose.yml
docker-compose*.yaml
.dockerignore

# ==============================================================================
# Database & Persistent Data (should be mounted as volumes, not baked in)
# ==============================================================================
db/

# ==============================================================================
# Local Models (should be mounted as volumes or downloaded at runtime)
# ==============================================================================
models/

# ==============================================================================
# Testing & Evaluation Scripts
# ==============================================================================
scripts/

# ==============================================================================
# Documentation
# ==============================================================================
README.md
LICENSE
*.md

# ==============================================================================
